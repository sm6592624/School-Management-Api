# Production Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file with real credentials

# Server Port
PORT=5000

# Node Environment
NODE_ENV=production

# Database Configuration (Use a REMOTE MySQL service, NOT localhost)
# Recommended: PlanetScale, AWS RDS, or DigitalOcean Managed Database

DB_HOST=your-database.psdb.cloud
DB_USER=your_username_here
DB_PASSWORD=your_secure_password_here
DB_NAME=school_management

# Example for PlanetScale:
# DB_HOST=aws.connect.psdb.cloud
# DB_USER=xxxxx
# DB_PASSWORD=xxxxx
# DB_NAME=school_management

# Example for AWS RDS:
# DB_HOST=your-db-instance.xxxxx.us-east-1.rds.amazonaws.com
# DB_USER=admin
# DB_PASSWORD=xxxxx
# DB_NAME=school_management
