  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"ABC High School\",\n  \"address\": \"123 Main Street, New York, NY 10001\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
        },
        "url": {
          "raw": "{{base_url}}/addSchool",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "addSchool"
          ]
        },
        "description": "Add a new school to the database\n\nRequired fields:\n- name: School name (string)\n- address: School address (string)\n- latitude: School latitude (number)\n- longitude: School longitude (number)"
      },
      "response": []
    },
